# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/products?retryWrites=true&w=majority

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS (set to EC2 public IP after launch) ──────────────────────────────────
CORS_ORIGIN=*

# ── AWS Credentials (get from: AWS Academy → Details → AWS CLI → Show) ────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=ASIA...
AWS_SECRET_ACCESS_KEY=...
AWS_SESSION_TOKEN=...          # Required for AWS Academy temporary credentials

# ── S3 Bucket ────────────────────────────────────────────────────────────────
AWS_BUCKET_NAME=goodsie-product-images
